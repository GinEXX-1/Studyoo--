# Studyoo 后端环境变量模板
# 复制此文件为 .env 并填入实际值

# 服务端口（默认 3000）
PORT=3000

# SQLite 数据库路径（默认 ./studyoo.db）
DATABASE_PATH=./studyoo.db

# JWT 签名密钥（生产环境务必替换为随机字符串）
JWT_SECRET=dev-only-change-me

# JWT 过期时间（默认 7d）
JWT_EXPIRES_IN=7d

# AI 服务提供商标识（默认 bigmodel）
AI_PROVIDER=bigmodel

# AI API 密钥（必填，否则 AI 功能不可用）
AI_API_KEY=

# AI 模型名称（默认 glm-4-flash）
AI_MODEL=glm-4-flash

# 图片识题模型（智谱免费视觉模型）
AI_VISION_MODEL=glm-4.6v-flash

# AI API 地址（智谱 BigModel 兼容 OpenAI 协议）
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# AI 调用超时毫秒数（默认 60000 = 60 秒）
AI_TIMEOUT_MS=60000

# 每日 AI 使用次数上限（默认 30）
AI_DAILY_LIMIT=30
UPLOAD_DIR=./uploads
PDF_RENDER_COMMAND=pdftoppm
PDF_TEXT_COMMAND=pdftotext

# 前端跨域来源（逗号分隔；默认含 localhost 与 studyoo.space）
CORS_ORIGIN=http://localhost:4173,http://localhost:5173

# API 根路径响应中展示的前端地址
FRONTEND_URL=http://localhost:5173

# 全站每日 AI 总额度（防批量注册烧穿余额，默认 200）
AI_GLOBAL_DAILY_LIMIT=200

# 内测邀请码（设置后注册必须携带；留空 = 开放注册）
INVITE_CODE=

# 逗号分隔的管理员昵称。管理员可访问 /api/v1/admin/*
# 已存在账号会在启动时提升；新建保留昵称还必须提供下方一次性初始化密钥
ADMIN_NICKNAMES=

# 管理员账号初始化密钥。仅服务端/API 初始化时使用，不得放入前端环境变量
ADMIN_BOOTSTRAP_TOKEN=

# 账户页与反馈记录展示的应用版本
APP_VERSION=2.4.0

# 运营统计时区偏移（分钟）；中国标准时间为 UTC+8，即 480
APP_TIMEZONE_OFFSET_MINUTES=480

# Admin 网页采集允许访问的域名，逗号分隔；留空时关闭服务端抓取
DISCOVERY_ALLOWED_HOSTS=

# 数据库备份（生产自动开启；本地可设 BACKUP_ENABLED=true 手动开启）
# BACKUP_DIR=/data/backups
# BACKUP_KEEP=14

# 备份异地推送（S3 兼容对象存储，如 Cloudflare R2；四项都配置才启用）
# BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# BACKUP_S3_BUCKET=studyoo-backups
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_REGION=auto

# 按 token 成本的 AI 配额（0 = 不启用；次数护栏防滥用频率，token 护栏防成本）
# AI_DAILY_TOKEN_LIMIT=200000
# AI_GLOBAL_DAILY_TOKEN_LIMIT=2000000
