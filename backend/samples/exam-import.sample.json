      "id": "custom-math-2024-001",
      "title": "代数恒等变形",
      "question_number": "1",
      "question_type": "填空题",
      "content_text": "已知 $a>0$，且 $a+\\frac{1}{a}=3$，求 $a^2+\\frac{1}{a^2}$。",
      "official_answer_text": "由 $(a+\\frac{1}{a})^2=a^2+2+\\frac{1}{a^2}=9$，得 $a^2+\\frac{1}{a^2}=7$。",
      "knowledge_tags": ["基本不等式", "代数恒等变形"],
      "difficulty": "easy"
    }
  ]
